# Backend Environment Variables Template
# Copy this file to .env and fill in the values for local development.

PORT=5002
NODE_ENV=development

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Geofencing coordinates
OFFICE_LAT=12.9716
OFFICE_LONG=77.5946
OFFICE_RADIUS=500

# Vercel Deployment Note:
# For production deployments, instead of serviceAccountKey.json,
# paste the entire JSON file contents into this variable:
FIREBASE_SERVICE_ACCOUNT=
